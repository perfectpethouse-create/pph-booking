rules_version = '2';
// กฎความปลอดภัย Firestore สำหรับ Perfect Pet House
// อนุญาตให้อ่าน/เขียนได้เฉพาะผู้ใช้ที่ล็อกอินแล้วเท่านั้น (พนักงานร้าน)
// วางกฎนี้ที่: Firebase Console → Firestore Database → แท็บ Rules → Publish
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
