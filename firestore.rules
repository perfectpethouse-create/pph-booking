rules_version = '2';
// กฎความปลอดภัย Firestore สำหรับ Perfect Pet House
// วางกฎนี้ที่: Firebase Console → Firestore Database → แท็บ Rules → Publish
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ตัวช่วยเช็คสิทธิ์ ──
    function signedIn() {
      return request.auth != null;
    }
    // "พี่เลี้ยง" = อีเมลอยู่ใน settings/app.staffEmails (ตั้งได้ในหน้า "ตั้งค่า")
    // ลิสต์ว่าง/ไม่มีเอกสาร settings = ทุกคนเป็นเจ้าของร้าน (กันล็อกตัวเองออก)
    function staffEmails() {
      return exists(/databases/$(database)/documents/settings/app)
        ? get(/databases/$(database)/documents/settings/app).data.get('staffEmails', [])
        : [];
    }
    function isStaff() {
      return signedIn() && request.auth.token.email in staffEmails();
    }
    function isOwner() {
      return signedIn() && !isStaff();
    }

    // ── กล่องรับใบลงทะเบียนจากเว็บ perfectbkk.com/checkin.html ──
    // ลูกค้า (ไม่ล็อกอิน) "ส่งเข้า" ได้อย่างเดียว — อ่าน/แก้/ลบได้เฉพาะพนักงานที่ล็อกอิน
    match /checkinForms/{doc} {
      allow create: if true;
      allow read, update, delete: if signedIn();
    }

    // ── กล่องรับคำขอจองจากฟอร์มจองบนเว็บ (index / app / exercise-zone) ──
    // หลักการเดียวกัน: ส่งเข้าได้จากภายนอก อ่าน/จัดการเฉพาะพนักงาน
    match /bookingRequests/{doc} {
      allow create: if true;
      allow read, update, delete: if signedIn();
    }

    // ── การจอง (มีราคา/ยอดเงิน) ──
    // พี่เลี้ยงอ่านได้ (ดูปฏิทิน/งานวันนี้) และ "สร้างใหม่" ได้ เพื่อรับจองหน้าเคาน์เตอร์
    // แต่แก้ไข/ลบใบที่มีอยู่แล้วไม่ได้ — กันแก้ยอดเงินหรือลบใบทิ้งย้อนหลัง
    // หมายเหตุ: สวิตช์เปิด-ปิดเมนูใน settings/app.staffPerms เป็นการควบคุมหน้าจอเท่านั้น
    //          ด่านจริงคือกฎ create/update/delete บรรทัดล่างนี้
    match /bookings/{doc} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isOwner();
    }

    // ── นัดหมายรายรอบ: Grooming / โซนออกกำลังกาย (มีราคา) ──
    // หลักการเดียวกับ bookings: พี่เลี้ยงจองคิวหน้าเคาน์เตอร์ได้ แต่แก้/ลบใบเดิมไม่ได้
    // (ต้องประกาศไว้ตรงนี้ อย่าปล่อยให้ตกไปที่กฎรวมท้ายไฟล์ซึ่งเปิด write ให้ทุกคนที่ล็อกอิน)
    match /appointments/{doc} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isOwner();
    }

    // ── ราคากลางที่หน้าเว็บสาธารณะอ่านได้ ──
    // อ่านได้โดยไม่ต้องล็อกอิน (เว็บ exercise-zone.html ดึงไปแสดง) แต่แก้ได้เฉพาะเจ้าของร้าน
    // ข้างในมีแค่ตารางราคาที่ประกาศบนเว็บอยู่แล้ว ไม่มีข้อมูลลูกค้าหรือยอดขาย
    match /publicInfo/{doc} {
      allow read: if true;
      allow write: if isOwner();
    }

    // ── ตั้งค่า (ราคา/สิทธิ์พนักงาน) — เจ้าของร้านเท่านั้นที่แก้ได้ ──
    // (กันพี่เลี้ยงลบอีเมลตัวเองออกจากลิสต์เพื่อเลื่อนสิทธิ์)
    match /settings/{doc} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // ── ลูกค้า & สัตว์เลี้ยง — พี่เลี้ยงแก้ได้ (อัปเดตโน้ตสุขภาพ/วัคซีน) ──
    match /customers/{doc} {
      allow read, write: if signedIn();
    }

    // ── อื่นๆ: ต้องล็อกอิน ──
    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
